# ── Database ─────────────────────────────────────────────────────────────────
# Local Postgres (docker-compose default)
DATABASE_URL=postgresql://jobsignals:jobsignals_dev@localhost:5432/jobsignals

# When migrating to cloud, swap this to your cloud warehouse URL, e.g.:
# BigQuery:   bigquery://project/dataset
# Snowflake:  snowflake://user:pass@account/db/schema
# Neon:       postgresql://user:pass@host/db?sslmode=require

POSTGRES_USER=jobsignals
POSTGRES_PASSWORD=jobsignals_dev
POSTGRES_DB=jobsignals

# ── pgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@jobsignals.local
PGADMIN_PASSWORD=admin

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_LOG_LEVEL=info

# ── Pipeline ──────────────────────────────────────────────────────────────────
DATASET_VERSION=1.0.0
PIPELINE_BATCH_SIZE=500

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Cron-style intervals (seconds). Default: every 6 hours for ingestion, daily for aggregations
INGESTION_INTERVAL_SECONDS=21600
AGGREGATION_INTERVAL_SECONDS=86400

# ── LLM — Groq ───────────────────────────────────────────────────────────────
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...
# Optional: override the model (default: llama-3.3-70b-versatile)
# INSIGHTS_MODEL=llama-3.3-70b-versatile

# ── Adzuna (salary data + 5,000 jobs/day free tier) ──────────────────────────
# Register at: https://developer.adzuna.com/
ADZUNA_APP_ID=your-app-id
ADZUNA_APP_KEY=your-app-key

# ── Jooble (free API — 71 countries including India) ─────────────────────────
# Register at: https://jooble.org/api/about (free, instant key)
JOOBLE_API_KEY=your-jooble-api-key
